{{- $pages := where .Site.RegularPages "Section" "!=" "" -}}
{{- $sections := .Site.Sections -}}
{
    "version": "1.0.0",
    "name": "{{ .Site.Title }}",
    "description": "Ensono Stacks Security Operations Body of Knowledge - MCP-compatible documentation index",
    "baseURL": "{{ .Site.BaseURL }}",
    "generatedAt": "{{ now.Format "2006-01-02T15:04:05Z07:00" }}",
    "capabilities": {
        "search": true,
        "browse": true,
        "context": true
    },
    "metadata": {
        "language": "{{ .Site.LanguageCode }}",
        "author": "{{ .Site.Params.author.name }}",
        "source": "https://github.com/Ensono/stacks-secops-bok",
        "topics": [
            "security-operations",
            "vulnerability-management",
            "dependency-management",
            "ensono-stacks"
        ]
    },
    "sections": [
        {{- $sectionCount := len $sections -}}
        {{- range $index, $section := $sections -}}
        {
            "id": "{{ $section.Section }}",
            "title": "{{ $section.Title }}",
            "path": "{{ $section.RelPermalink }}",
            "weight": {{ $section.Weight }},
            "description": {{ if $section.Description }}"{{ $section.Description }}"{{ else }}"{{ $section.Summary | plainify }}"{{ end }},
            "pages": [
                {{- $sectionPages := where $pages "Section" $section.Section -}}
                {{- $pageCount := len $sectionPages -}}
                {{- range $pindex, $page := $sectionPages -}}
                {
                    "id": "{{ md5 $page.Permalink }}",
                    "title": "{{ $page.Title }}",
                    "path": "{{ $page.RelPermalink }}",
                    "url": "{{ $page.Permalink }}",
                    "weight": {{ $page.Weight }},
                    "summary": "{{ $page.Summary | plainify | truncate 200 }}",
                    "keywords": [
                        {{- if $page.Params.tags -}}
                        {{- range $tindex, $tag := $page.Params.tags -}}
                        "{{ $tag }}"{{- if ne $tindex (sub (len $page.Params.tags) 1) -}},{{- end -}}
                        {{- end -}}
                        {{- else -}}
                        "{{ $section.Section }}"
                        {{- end -}}
                    ],
                    "content": {
                        "wordCount": {{ $page.WordCount }},
                        "readingTime": {{ $page.ReadingTime }},
                        "plainText": {{ $page.Plain | jsonify }}
                    },
                    "metadata": {
                        "section": "{{ $section.Title }}",
                        "lastModified": "{{ $page.Lastmod.Format "2006-01-02T15:04:05Z07:00" }}",
                        "publishDate": "{{ $page.PublishDate.Format "2006-01-02T15:04:05Z07:00" }}"
                    }
                }{{- if ne $pindex (sub $pageCount 1) -}},{{- end -}}
                {{- end }}
            ]
        }{{- if ne $index (sub $sectionCount 1) -}},{{- end -}}
        {{- end }}
    ],
    "searchIndex": {
        "description": "Searchable content from Stacks SecOps BOK",
        "entries": [
            {{- $allPages := $pages -}}
            {{- $entryCount := len $allPages -}}
            {{- range $eindex, $page := $allPages -}}
            {
                "id": "{{ md5 $page.Permalink }}",
                "title": "{{ $page.Title }}",
                "section": "{{ $page.Section }}",
                "url": "{{ $page.Permalink }}",
                "content": {{ $page.Plain | jsonify }},
                "keywords": "{{ delimit (union (slice $page.Section $page.Title) (default slice $page.Params.tags)) " " }}"
            }{{- if ne $eindex (sub $entryCount 1) -}},{{- end -}}
            {{- end }}
        ]
    },
    "tools": {
        "query": {
            "description": "Search the documentation content",
            "parameters": {
                "query": "string",
                "section": "string (optional)"
            }
        },
        "getPage": {
            "description": "Retrieve a specific page by ID or path",
            "parameters": {
                "id": "string (page ID)",
                "path": "string (page path)"
            }
        },
        "browse": {
            "description": "Browse documentation by section",
            "parameters": {
                "section": "string"
            }
        }
    }
}
